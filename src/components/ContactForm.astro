---
---
<form class="card-glass p-6 space-y-4 max-w-xl">
  <label class="block">
    <span class="text-sm text-gray-300">Nombre</span>
    <input class="mt-1 w-full rounded-md bg-transparent border border-white/6 p-3 text-white" placeholder="Tu nombre" />
  </label>
  <label class="block">
    <span class="text-sm text-gray-300">Email</span>
    <input class="mt-1 w-full rounded-md bg-transparent border border-white/6 p-3 text-white" placeholder="tu@ejemplo.com" />
  </label>
  <label class="block">
    <span class="text-sm text-gray-300">Mensaje</span>
    <textarea class="mt-1 w-full rounded-md bg-transparent border border-white/6 p-3 text-white" rows="4"></textarea>
  </label>
  <div class="flex items-center justify-between">
    <button class="btn-cta" type="submit">Enviar mensaje</button>
    <div class="text-sm text-gray-400">O llámanos: <span class="neon">+61 400 000 000</span></div>
  </div>
</form>
