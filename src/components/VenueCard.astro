---
const {image, name, amenities, mapThumb, delay} = Astro.props;
---
<div class="card-glass p-4 flex flex-col gap-3 reveal" data-delay={delay || 0}>
  <div class="h-40 bg-cover bg-center rounded-md" style={`background-image:url(${image})`}></div>
  <div class="flex items-center justify-between">
    <h4 class="font-semibold">{name}</h4>
    <span class="text-sm neon">Abierto</span>
  </div>
  <div class="text-xs text-gray-300 flex gap-3">
    {amenities.map(a => <span class="inline-flex items-center gap-2">{a}</span>)}
  </div>
  <div class="h-20 mt-2 rounded-md overflow-hidden">
    <img src={mapThumb} alt="mapa" class="w-full h-full object-cover"/>
  </div>
</div>
